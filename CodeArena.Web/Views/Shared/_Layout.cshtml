<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeArena</title>
    <link rel="icon" href="~/img/public_logo.png" type="image/png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeArena.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.css"/>
    @await RenderSectionAsync("Styles", false)
</head>
<body id="appBody" class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light border-bottom shadow-sm py-2 mb-2">
            <div class="container-fluid px-4 mt-1">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-code-slash me-2"></i>CodeArena
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?
                                  .ToString()?.ToLower() == "home" ? "active fw-bold" : "")" 
                            asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?
                                            .ToString()?.ToLower() == "challenges" ? "active fw-bold" : "")" 
                            asp-controller="Challenges" asp-action="Index">
                                <i class="bi bi-journal-check me-1"></i> Challenges
                            </a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?
                                        .ToString()?.ToLower() == "submissions" ? "active fw-bold" : "")" 
                                asp-controller="Submissions" asp-action="Index">
                                    <i class="bi bi-journal-code me-1"></i> Submissions
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link leaderboard-link @(ViewContext.RouteData.Values["controller"]?
                                        .ToString()?.ToLower() == "leaderboard" ? "active fw-bold" : "")"
                                   asp-controller="Leaderboard" asp-action="Index">
                                <span class="d-flex align-items-center gap-1 px-2 py-1 rounded">
                                    <i class="bi bi-trophy-fill"></i> Leaderboard
                                </span>
                            </a>
                        </li>
                    </ul>
                    <hr class="d-lg-none my-2" />
                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link fw-semibold" asp-controller="Profile" asp-action="Stats">
                                    <i class="bi bi-bar-chart-line me-1"></i> Stats
                                </a>
                            </li>
                        }

                        <li class="nav-item me-3">
                            <button id="themeToggle" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-moon"></i>
                                <span class="d-lg-none ms-1 ms-lg-0">Theme</span>
                            </button>
                        </li>

                         <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-lg">
        <main role="main" class="pb-3 flex-fill">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top mt-auto py-3 text-muted">
        <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-1 gap-sm-2 text-center">
            <span>© 2026 CodeArena</span>
            <span>•</span>          
            <span>Built with ASP.NET MVC</span>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js" integrity="sha512-lbwH47l/tPXJYG9AcFNoJaTMhGvYWhVM9YI43CT+uteTRRaiLCui8snIgyAN8XWgNjNhCqlAUdzZptso6OCoFQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <partial name="_NotificationPartial" />
</body>
</html>
