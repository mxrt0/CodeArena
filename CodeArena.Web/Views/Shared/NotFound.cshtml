@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:70vh;">
    <div class="text-center">

        <div class="mb-1">
            <i class="bi bi-emoji-frown text-warning" style="font-size: 8rem;"></i>
        </div>

        <h1 class="display-5 fw-bold text-warning">404 - Page Not Found</h1>

        <p class="text-muted mt-3 mb-4">
            Sorry, the page you are looking for doesn't exist or it may have been moved or deleted.
            Please check the URL.
        </p>

        <div class="d-flex justify-content-center gap-3">

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-door"></i>
                Back to Home
            </a>

            <button class="btn btn-outline-secondary" onclick="history.back()">
                <i class="bi bi-arrow-left"></i>
                Go Back
            </button>

        </div>

    </div>
</div>