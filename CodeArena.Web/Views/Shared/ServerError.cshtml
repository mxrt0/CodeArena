@{
    ViewData["Title"] = "Server Error";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:70vh;">
    <div class="text-center">

        <div class="mb-1">
            <i class="bi bi-x-octagon-fill text-danger" style="font-size: 8rem;"></i>
        </div>

        <h1 class="display-5 fw-bold text-danger">500 - Internal Server Error</h1>

        <p class="text-muted mt-3 mb-4">
            Something went wrong on our end. The server encountered an unexpected error
            and couldn't complete your request. Please try again later.
        </p>

        <div class="d-flex justify-content-center gap-3">

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-door"></i>
                Back to Home
            </a>
        </div>

    </div>
</div>