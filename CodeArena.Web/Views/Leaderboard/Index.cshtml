@model LeaderboardIndexViewModel
@{
    ViewData["Title"] = "Leaderboard";
}

<div class="text-center mb-4">
    <h1 class="fw-bold">
        <i class="bi bi-trophy-fill text-warning me-2"></i>
        Leaderboard
    </h1>
    <p class="text-muted mb-0">
        Compete with others and climb the ranks
    </p>
</div>
@if (!Model.Leaderboard.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-people display-5 text-muted"></i>
        <h5 class="mt-3">No rankings yet</h5>
    </div>
}
else
{
    <div class="card shadow-sm leaderboard-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle text-center">
                    <thead>
                        <tr>
                            <th scope="col">Rank</th>
                            <th scope="col">User</th>
                            <th scope="col"><i class="bi bi-stars"></i> Total XP</th>
                            <th scope="col" class="d-none d-sm-table-cell"><i class="bi bi-trophy"></i> Challenges Solved</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Leaderboard)
                        {
                            var isCurrentUser = entry.UserId == Model.CurrentUserId;
                            var rowClass = isCurrentUser ? "current-user-row fw-semibold" : "";
                            var topClass = entry.Rank switch
                            {
                                1 => "top-1",
                                2 => "top-2",
                                3 => "top-3",
                                _ => ""
                            };
                            <tr class="@rowClass @topClass">
                                <td>
                                    @switch (entry.Rank)
                                    {
                                        case 1:
                                            <span class="fs-5">🥇</span>
                                            break;
                                        case 2:
                                            <span class="fs-5">🥈</span>
                                            break;
                                        case 3:
                                            <span class="fs-5">🥉</span>
                                            break;
                                        default:
                                            @entry.Rank
                                            break;
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <i class="bi bi-person-circle text-muted"></i>
                                        <span>@entry.DisplayName</span>
                                    </div>
                                </td>
                                <td class="fw-bold text-warning">
                                    <i class="bi bi-lightning-charge me-1"></i>
                                    @entry.TotalXp
                                </td>
                                <td class="d-none d-sm-table-cell">@entry.ChallengesSolved</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
@section Styles {
    <style>
    .table > tbody > tr.top-1 > td { background-color: rgba(255, 215, 0, 0.15); }
    .table > tbody > tr.top-2 > td { background-color: rgba(192, 192, 192, 0.15); }
    .table > tbody > tr.top-3 > td { background-color: rgba(205, 127, 50, 0.15); }
    .table > tbody > tr.current-user-row > td { background-color: rgba(13, 110, 253, 0.1); }
    </style>
}
@section Scripts {
    <script>
        const currentUserId = '@(Model.CurrentUserId)';
    </script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/leaderboard.js"></script>
 }