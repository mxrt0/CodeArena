@model ChallengeDetailsViewModel
@{
    ViewData["Title"] = Model.Challenge.Title;
}
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/eclipse.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/dracula.min.css">
}
<div class="container mt-4">
    <div class="card shadow-sm challenge-details-card">
        <div class="card-body d-flex flex-column">

            <h2 class="card-title mb-3 fw-bolder">
                @Model.Challenge.Title
            </h2>

            <div class="mb-1">
                <span class="badge fs-6
                    @(Model.Challenge.Difficulty == "Easy" ? "bg-success" :
                                              Model.Challenge.Difficulty == "Medium" ? "bg-warning" :
                                              "bg-danger")">
                    @Model.Challenge.Difficulty
                </span>
            </div>

            @if (Model.Challenge.Tags != null && Model.Challenge.Tags.Any())
            {
                <div class="mb-3">
                    @foreach (var tag in Model.Challenge.Tags)
                    {
                        <span class="badge bg-secondary me-1">
                            <i class="bi bi-tags me-1"></i>@tag
                        </span>
                    }
                </div>
            }

            <hr />

            <pre class="p-3 border rounded font-monospace">@Model.Challenge.Description</pre>

            @if (User?.Identity?.IsAuthenticated ?? false)
            {
                <hr />
                @if (Model.Challenge.HasPendingSubmission)
                {
                    <div class="alert alert-warning text-center w-75 mx-auto mt-3">
                        <i class="bi bi-clock-history me-1"></i>
                        You already have a submission pending review.
                    </div>

                    <a asp-controller="Submissions" asp-action="Index" class="btn btn-info d-block m-auto mt-2">
                        View Your Submissions
                    </a>
                }
                else if (Model.Challenge.IsSolved)
                {
                    <div class="alert alert-success text-center w-75 mx-auto mt-3">
                        <i class="bi bi-check-circle me-1"></i>
                        You have solved this challenge!
                    </div>

                    <a asp-controller="Submissions" asp-action="Index" class="btn btn-info d-block m-auto mt-2">
                        View Your Submissions
                    </a>
                }
                else
                {
                    <h5 class="mt-4">
                        <i class="bi bi-code-slash me-1"></i>
                        Submit Your Solution
                    </h5>

                    <form asp-controller="Submissions" asp-action="Create" method="post">
                        <input type="hidden" name="ChallengeId" value="@Model.Challenge.Id" />

                        <div class="mb-3">
                            <textarea class="form-control font-monospace"
                                      asp-for="SolutionCode"
                                      rows="8"
                                      required></textarea>
                            <span asp-validation-for="SolutionCode" class="text-danger"></span>
                        </div>

                        <div class="mb-3 w-25">
                            <label asp-for="Language" class="form-label fw-bold">Language</label>
                            <select class="form-select" asp-for="Language" required>
                                <option value="">--Select--</option>
                                <option value="CSharp">C#</option>
                                <option value="JavaScript">JavaScript</option>
                                <option value="Python">Python</option>
                                <option value="Java">Java</option>
                            </select>
                            <span asp-validation-for="Language" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success d-block m-auto">
                            <i class="bi bi-upload me-1"></i>Submit</button>
                    </form>
                }
            }
            else
            {
                <div class="alert alert-info mt-4 text-center">
                    Please <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Challenges/Details/@Model.Challenge.Id">login</a> to submit your solution.
                </div>
            }

            <a asp-action="Index" class="btn btn-outline-secondary d-block m-auto mt-2">
                <i class="bi bi-arrow-left me-1"></i>
                Back
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/clike/clike.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/javascript/javascript.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/python/python.min.js"></script>
    <script src="~/js/codeMirror.js"></script>
}