@model ChallengeIndexViewModel
@{
    ViewData["Title"] = "Challenges";
}

<div class="container mt-4 challenge-page">

    <form id="filter-form" method="get" class="challenge-filter-bar mb-4">

        <div class="d-flex flex-wrap align-items-center gap-2">

            <div class="flex-grow-1" style="min-width: 200px;">
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="Search challenges..." />
            </div>

            <select name="selectedDifficulty" class="form-select w-auto">
                <option value="">All Difficulties</option>
                @foreach (var d in Enum.GetValues<Difficulty>())
                {
                    if (Model.SelectedDifficulty == d)
                    {
                        <option value="@d.ToString().ToLower()" selected>@d</option>
                    }
                    else
                    {
                    <option value="@d.ToString().ToLower()">@d</option>
                    }
                }
            </select>

            <select name="statusFilter" class="form-select w-auto">
                <option value="">All Challenges</option>
                @foreach (var d in Enum.GetValues<ChallengeStatus>())
                {
                    if (d == ChallengeStatus.All) continue;

                    if (Model.StatusFilter == d)
                    {
                        <option value="@d.ToString().ToLower()" selected>@d</option>
                    }
                    else
                    {
                        <option value="@d.ToString().ToLower()">@d</option>
                    }
                }
            </select>

            <a asp-action="Index" class="btn btn-outline-danger">
                <i class="bi bi-x-lg"></i>
            </a>

        </div>

        <div class="tag-filter mt-3 d-flex flex-wrap gap-2">

            @foreach (var tag in Model.AvailableTags)
            {
                var isSelected = Model.Tags.Contains(tag);

                <label class="tag-chip @(isSelected ? "active" : "")">
                    <input type="checkbox"
                           name="tags"
                           value="@tag"
                    @(isSelected ? "checked" : "") />
                    <span>@tag</span>
                </label>
            }

        </div>

    </form>

    @if (!Model.Challenges.Any())
    {
        <div class="text-center py-5">

            <i class="bi bi-search display-5 text-muted"></i>

            <h5 class="mt-3 fw-semibold">No challenges found</h5>

            <p class="text-muted mb-3">
                Try adjusting your filters.
            </p>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Clear Filters
            </a>

        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var challenge in Model.Challenges)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm challenge-card">
                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-bold mb-2">
                                @challenge.Title
                            </h5>

                            <div class="mb-2 d-flex gap-2 flex-wrap">
                                @if (challenge.IsSolved)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>
                                        Solved
                                    </span>
                                }
                                else if (challenge.HasPendingSubmission)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-hourglass-split me-1"></i>
                                        Awaiting Review
                                    </span>
                                }
                            </div>

                            <p class="card-text text-muted flex-grow-1 text-truncate">
                                @(challenge.Description.Length <= 200
                                    ? challenge.Description
                                    : challenge.Description.Substring(0,
                                          challenge.Description.IndexOf(' ', 200)) + "...")
                            </p>

                            <div class="mb-2 d-flex gap-1 flex-wrap">
                                <span class="badge
                                    @(challenge.Difficulty == "Easy" ? "bg-success" :
                                                                            challenge.Difficulty == "Medium" ? "bg-warning text-dark" :
                                                                            "bg-danger")">
                                    <i class="bi bi-bar-chart-line me-1"></i>
                                    @challenge.Difficulty
                                </span>

                                @if (challenge.Tags != null && challenge.Tags.Any())
                                {
                                    @foreach (var tag in challenge.Tags)
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-tags me-1"></i>@tag
                                        </span>
                                    }
                                }
                            </div>

                            <a     asp-route="challengeSlugs"
                                   asp-route-slug="@challenge.Slug"
                                   class="btn btn-outline-secondary t-auto">
                                <i class="bi bi-eye me-1"></i>
                                View Details
                            </a>

                        </div>
                    </div>
                </div>
            }
        </div>

            var baseRoute = new Dictionary<string, string?>();
            baseRoute["selectedDifficulty"] = Model.SelectedDifficulty?.ToString().ToLower();
            baseRoute["statusFilter"] = Model.StatusFilter.ToString().ToLower();
            baseRoute["search"] = Model.Search?.ToLower();
            baseRoute["page"] = Model.CurrentPage.ToString();

        var prevRoute = new Dictionary<string, string?>(baseRoute)
                {
                    ["page"] = (Model.CurrentPage - 1).ToString()
                };
        var nextRoute = new Dictionary<string, string?>(baseRoute)
        {
            ["page"] = (Model.CurrentPage - 1).ToString()
        };
        if (Model.Tags is not null && Model.Tags.Any())
            {
                var tagsArray = Model.Tags.ToArray();
                for (int i = 0; i < tagsArray.Length; i++)
                {
                    baseRoute[$"tags[{i}]"] = tagsArray[i];
                }
            }
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-all-route-data="@prevRoute">
                        &laquo; Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    var pageRoute = new Dictionary<string, string?>(baseRoute)
                    {
                        ["page"] = i.ToString()
                    };
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-all-route-data="@pageRoute">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-all-route-data="@nextRoute">
                        Next &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>