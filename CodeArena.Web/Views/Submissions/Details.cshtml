@model SubmissionDetailsViewModel

@{
    ViewData["Title"] = "Submission Details";
}

<div class="container mt-4 submission-details-page">

    <div class="card shadow-sm submission-details-card">

        <div class="card-body">

            <h2 class="card-title mb-3 fw-bold">
                @Model.Submission.ChallengeTitle
            </h2>

            <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">

                <span class="badge bg-secondary">
                    @Model.Submission.Language
                </span>

                <span class="badge
                    @(Model.Submission.Status == "Approved" ? "bg-success" :
                                            Model.Submission.Status == "Rejected" ? "bg-danger" :
                                            Model.Submission.Status == "Pending" ? "bg-warning" :
                                            "bg-secondary")">

                    @Model.Submission.Status
                    @if(Model.Submission.Status == "Approved")
                    {
                        <i class="bi bi-check-circle ms-1"></i>
                    }
                </span>

            </div>

            <p class="text-muted mb-3">
                Submitted on
                <strong>
                    @(Model.Submission.SubmittedAt
                        .ToString(DefaultDateFormat, CultureInfo.InvariantCulture))
                </strong>
            </p>

            <hr />

            @if (!string.IsNullOrWhiteSpace(Model.Submission.Feedback))
            {
                <div class="feedback-card mb-3 p-3 rounded shadow-sm border-left-info">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-chat-left-text me-2 fs-5 text-info"></i>
                        <strong>Admin Feedback</strong>
                    </div>
                    <p class="mb-0">@Model.Submission.Feedback</p>
                </div>

                <hr />
            }

            <h5 class="fw-semibold mb-3">
                <i class="bi bi-code-slash me-1"></i>
                Your Solution
            </h5>
            <div class="code-container position-relative p-0">
                <button class="copy-btn">
                    <i class="bi bi-clipboard"></i>
                </button>
                <pre><code class="language-@Model.Submission.Language.ToLower()">@Model.Submission.SolutionCode</code></pre>
            </div>

            <div class="mt-3 d-flex gap-2 flex-wrap">

                <a asp-controller="Challenges"
                       asp-action="Details"
                       asp-route-id="@Model.Submission.ChallengeId"
                       class="btn btn-outline-primary">
                    <i class="bi bi-box-arrow-up-right me-1"></i>
                    <span class="d-none d-md-inline">View Challenge</span>
                </a>

                <a asp-action="Index"
                       class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>
                    <span class="d-none d-md-inline">Back</span>
                </a>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/copyToClipboard.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>
        hljs.highlightAll();
    </script>
}