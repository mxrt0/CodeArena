@model SubmissionsIndexViewModel

@{
    ViewData["Title"] = "My Submissions";
}

<div class="container mt-4 submissions-page">

    <h2 class="mb-4 fw-bold text-center">
        <i class="bi bi-journal-code me-2"></i>
        My Submissions
    </h2>
    <form id="filter-form" method="get" class="d-flex gap-2 mb-4 w-50">

            <select name="status" class="form-select w-auto">
                <option value="">All</option>
                @foreach (var d in Enum.GetValues<SubmissionStatus>())
                {
                    if (Model.Status == d)
                    {
                        <option value="@d.ToString().ToLower()" selected>@d</option>
                    }
                    else
                    {
                        <option value="@d.ToString().ToLower()">@d</option>
                    }
                }
            </select>

            <select name="language" class="form-select w-auto">
                <option value="">All Languages</option>
                @foreach (var d in Enum.GetValues<SubmissionLanguage>())
                {
                    if (Model.Language == d)
                    {
                    <option value="@d.ToString().ToLower()" selected>@d</option>
                    }
                    else
                    {
                    <option value="@d.ToString().ToLower()">@d</option>
                    }
                }
            </select>

            <a asp-action="Index" class="btn btn-outline-danger">
                <i class="bi bi-x-lg"></i>
            </a>

    </form>
    <div class="card shadow-sm submissions-card">

        @if (!Model.Submissions.Any())
        {
            if (!Context.Request.Query.Any())
            {
                <div class="text-center py-5">

                    <i class="bi bi-inbox display-5 text-muted"></i>

                    <h5 class="mt-3 fw-semibold">No submissions yet</h5>

                    <p class="text-muted mb-3">
                        Start solving challenges to see your progress here.
                    </p>

                    <a asp-controller="Challenges"
                           asp-action="Index"
                           class="btn btn-primary">
                        <i class="bi bi-arrow-down-right-circle me-1"></i>
                        Browse Challenges
                    </a>

                </div>
            }
            else
            {
                <div class="text-center py-5">

                    <i class="bi bi-search display-5 text-muted"></i>

                    <h5 class="mt-3 fw-semibold">No submissions found</h5>

                    <p class="text-muted mb-3">
                        Try adjusting your filters.
                    </p>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Clear Filters
                    </a>
                </div>
            }
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle submissions-table mb-0">

                    <thead>
                        <tr>
                            <th>Challenge</th>
                            <th>Language</th>
                            <th>Submitted</th>
                            <th>Status</th>
                            <th>Feedback</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var s in Model.Submissions)
                        {
                            <tr class="submission-row @(s.Status == "Rejected" ? "rejected-row" : "")">

                                <td>
                                    <span class="fw-semibold">@s.ChallengeTitle</span>
                                </td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @s.Language
                                    </span>
                                </td>

                                <td>
                                    @s.SubmittedAt.ToString(ApplicationConstants.DefaultDateFormat,
                                    CultureInfo.InvariantCulture)
                                </td>

                                <td>
                                    <span class="badge
                                        @(s.Status == "Approved" ? "bg-success"
                                                                                    : s.Status == "Rejected" ? "bg-danger"
                                                                                    : "bg-warning")">
                                        @s.Status
                                    </span>
                                </td>

                                <td title="@s.Feedback">
                                    @(s.Feedback?.Length > 50
                                        ? s.Feedback.Substring(0, 50) + "..."
                                        : s.Feedback)
                                </td>

                                <td class="text-end">
                                    <a asp-action="Details"
                                           asp-route-id="@s.SubmissionId"
                                           class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-eye me-1"></i>
                                        <span class="d-none d-md-inline">View</span>
                                    </a>

                                    <a asp-route="challengeSlugs"
                                           asp-route-slug="@s.ChallengeSlug"
                                           class="btn btn-sm btn-outline-secondary me-1">
                                        <i class="bi bi-box-arrow-up-right me-1"></i>
                                        <span class="d-none d-md-inline">Challenge</span>
                                    </a>

                                    @if (s.Status == "Pending")
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#cancelSubmissionModal-@s.SubmissionId">
                                            <i class="bi bi-x-circle me-1"></i>
                                            <span class="d-none d-md-inline">Cancel</span>
                                        </button>
                                    }
                                </td>

                            </tr>

                            @if (s.Status == "Pending")
                            {
                                <partial name="_ConfirmCancelSubmissionPartial" model="s" />
                            }
                        }
                    </tbody>

                </table>
            </div>
        }

    </div>

</div>

@if (Model.Submissions.Any())
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-status="@(Model.Status?.ToString().ToLower())"
                       asp-route-language="@(Model.Language?.ToString().ToLower())">
                    &laquo; Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-status="@(Model.Status?.ToString().ToLower())"
                           asp-route-language="@(Model.Language?.ToString().ToLower())">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-status="@(Model.Status?.ToString().ToLower())"
                       asp-route-language="@(Model.Language?.ToString().ToLower())">
                    Next &raquo;
                </a>
            </li>
        </ul>
    </nav>
}
