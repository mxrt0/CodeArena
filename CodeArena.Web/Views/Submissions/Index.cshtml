@model SubmissionsIndexViewModel

@{
    ViewData["Title"] = "My Submissions";
}

<div class="container mt-4">

    <h2 class="mb-4">My Submissions</h2>

    <div class="card shadow-sm">
            @if (!Model.Submissions.Any())
            {
                <div class="alert alert-info">
                    No submissions found.
                </div>
            }
            else
            {
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-primary table-responsive">
                        <tr>
                            <th>Challenge</th>
                            <th>Language</th>
                            <th>Submitted</th>
                            <th>Status</th>
                            <th>Feedback</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var s in Model.Submissions)
                        {
                            <tr class="@(s.Status == "Rejected" ? "table-danger" : "")">
                                <td>
                                    <p class="fw-bold">@s.ChallengeTitle</p>
                                </td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @s.Language
                                    </span>
                                </td>

                                <td>
                                    @s.SubmittedAt.ToString(ApplicationConstants.DefaultDateFormat,
                                    CultureInfo.InvariantCulture)
                        </td>

                        <td>
                            <span class="badge
                                        @(s.Status == "Approved" ? "bg-success"
                                                                          : s.Status == "Rejected" ? "bg-danger"
                                                                          : "bg-warning text-dark")">
                                        @s.Status
                                    </span>
                                </td>

                                <td title="@s.Feedback">
                                    @(s.Feedback?.Length > 50
                                        ? s.Feedback.Substring(0, 50) + "..."
                                        : s.Feedback)
                                </td>

                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@s.SubmissionId"
                                       class="btn btn-primary btn-sm">
                                        View
                                    </a>
                                    <a asp-controller="Challenges"
                                       asp-action="Details"
                                       asp-route-id="@s.ChallengeId"
                                       class="btn btn-secondary btn-sm">
                                        Go to Challenge
                                    </a>
                                    @if (s.Status == "Pending")
                                    {
                                        <button type="button"
                                                class="btn btn-danger btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#cancelSubmissionModal-@s.SubmissionId">
                                            Cancel
                                        </button>
                                    }
                                </td>
                            </tr>
                            @if (s.Status == "Pending")
                            {
                                <partial name="_ConfirmCancelSubmissionPartial" model="s" />
                            }
                        }
                    </tbody>

                </table>
            }
    </div>

</div>
<nav class="mt-2">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
            <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.CurrentPage - 1)">
                &laquo; Previous
            </a>
        </li>
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                    @i
                </a>
            </li>
        }
        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
            <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.CurrentPage + 1)">
                Next &raquo;
            </a>
        </li>
    </ul>
</nav>
