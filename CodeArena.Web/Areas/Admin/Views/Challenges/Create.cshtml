@model CreateChallengeViewModel

<h2>Create Challenge</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="Challenge.Title" class="form-label"></label>
        <input asp-for="Challenge.Title" class="form-control" />
        <span asp-validation-for="Challenge.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Challenge.Description" class="form-label"></label>
        <textarea asp-for="Challenge.Description" rows="5" class="form-control"></textarea>
        <span asp-validation-for="Challenge.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Challenge.Difficulty" class="form-label"></label>
        <select asp-for="Challenge.Difficulty" class="form-select">
            <option value="">--Select Difficulty--</option>
            <option value="Easy">Easy</option>
            <option value="Medium">Medium</option>
            <option value="Hard">Hard</option>
        </select>
        <span asp-validation-for="Challenge.Difficulty" class="text-danger"></span>
    </div>

    <button class="btn btn-success">Create</button>
</form>
