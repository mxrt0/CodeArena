@model CreateChallengeViewModel
@{
    ViewData["Title"] = "Create Challenge";
}

<div class="container mt-4 admin-create-page">

    <h2 class="mb-4 fw-bold">
        <i class="bi bi-plus-square me-2"></i>
        Create Challenge
    </h2>

    <div class="card shadow-sm create-card">
        <div class="card-body">

            <form asp-action="Create" method="post">

                <div class="mb-4">
                    <label asp-for="Challenge.Title" class="form-label fw-semibold"></label>
                    <input asp-for="Challenge.Title" class="form-control" />
                    <span asp-validation-for="Challenge.Title" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Challenge.Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Challenge.Description" rows="6" class="form-control"></textarea>
                    <span asp-validation-for="Challenge.Description" class="text-danger small"></span>
                </div>

                <div class="row">

                    <div class="col-md-6 mb-4">
                        <label asp-for="Challenge.Difficulty" class="form-label fw-semibold"></label>
                        <select asp-for="Challenge.Difficulty" class="form-select">
                            <option value="">-- Select Difficulty --</option>
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                        <span asp-validation-for="Challenge.Difficulty" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Challenge.Tags" class="form-label fw-semibold"></label>
                        <input asp-for="Challenge.Tags" class="form-control" placeholder="e.g. arrays, sorting" />
                    </div>

                </div>

                <div class="d-flex justify-content-center gap-2 mt-3">

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i>
                        Create
                    </button>

                    <a asp-action="Index" class="btn btn-outline-danger">
                        <i class="bi bi-x-circle me-1"></i>
                        Cancel
                    </a>

                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}