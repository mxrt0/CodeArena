@model ChallengesIndexViewModel

@{
    ViewData["Title"] = "Manage Challenges";
}

<div class="container mt-4 admin-challenges-page">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-trophy me-2"></i>
            Manage Challenges
        </h2>

        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>
            Create Challenge
        </a>
    </div>
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Difficulty</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var c in Model.Challenges)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @c.Title
                            </td>

                            <td>
                                <span class="badge
                                    @(c.Difficulty == "Easy" ? "bg-success" :
                                                                                                                  c.Difficulty == "Medium" ? "bg-warning text-dark" :
                                                                                                                  "bg-danger")">
                                    @c.Difficulty
                                </span>
                            </td>

                            <td>
                                <span class="badge @(c.IsDeleted ? "bg-danger" : "bg-success")">
                                    @(c.IsDeleted ? "Deleted" : "Active")
                                </span>
                            </td>

                            <td class="text-end">

                                <a asp-action="Edit"
                                       asp-route-id="@c.Id"
                                       class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil-square"></i>
                                    <span class="d-none d-md-inline ms-md-1">Edit</span>
                                </a>

                                @if (!c.IsDeleted)
                                {
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal-@c.Id">
                                        <i class="bi bi-trash"></i>
                                        <span class="d-none d-md-inline ms-md-1">Delete</span>
                                    </button>
                                }
                                else
                                {
                                    <form asp-action="Restore"
                                          asp-route-id="@c.Id"
                                          method="post"
                                          class="d-inline">

                                        <button type="submit"
                                                class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>
                                            Restore
                                        </button>

                                    </form>
                                }

                            </td>
                        </tr>

                        @if (!c.IsDeleted)
                        {
                            <partial name="_ConfirmDeletePartial" model="c" />
                        }
                    }
                </tbody>

            </table>

        </div>
    </div>
    </div>
        