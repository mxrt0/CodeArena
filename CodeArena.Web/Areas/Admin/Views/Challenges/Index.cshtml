@model ChallengesIndexViewModel

<h2>Manage Challenges</h2>

<a asp-action="Create" class="btn btn-primary mb-3 text-center w-25">Create New</a>

<div class="row">
    @foreach (var c in Model.Challenges)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@c.Title</h5>
                    <p class="card-text">Difficulty: @c.Difficulty</p>
                    <p class="card-text">
                        Status: <span class="badge @(c.IsDeleted ? "bg-danger" : "bg-success")">
                            @(c.IsDeleted ? "Deleted" : "Active")</span>
                    </p>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-info btn-sm">Edit</a>
                    @if (!c.IsDeleted)
                    {
                        <button type="button" class="btn btn-danger btn-sm"
                                data-bs-toggle="modal" data-bs-target="#deleteModal-@c.Id">
                            Delete
                        </button>
                        <partial name="_ConfirmDeletePartial" model="c" />
                    }
                    else
                    {
                        <form asp-action="Restore" asp-route-id="@c.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-warning btn-sm">
                                Restore
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
        
    }
</div>
