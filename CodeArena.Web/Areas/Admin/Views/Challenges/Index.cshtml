@model ChallengesIndexViewModel

<h2>Manage Challenges</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Create New</a>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Difficulty</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Challenges)
        {
            <tr>
                <td>@c.Title</td>
                <td>@c.Difficulty</td>
            </tr>
        }
    </tbody>
</table>
