@model ChallengesIndexViewModel

@{
    ViewData["Title"] = "Manage Challenges";
}

<div class="container mt-4 admin-challenges-page">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-trophy me-2"></i>
            Manage Challenges
        </h2>

        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>
            Create Challenge
        </a>
    </div>
    <form id="filter-form" method="get" class="d-flex gap-2 mb-4 w-50">

        <div class="flex-grow-1" style="min-width: 150px;">
            <input type="text"
                   name="search"
                   value="@Model.Search"
                   class="form-control"
                   placeholder="Search challenges..." />
        </div>

        <select name="state" class="form-select w-auto">
            <option value="all">All</option>
            @foreach (var d in Enum.GetValues<ChallengeState>())
            {
                if (d is ChallengeState.All) continue;

                if (Model.State == d)
                {
                    <option value="@d.ToString().ToLower()" selected>@d</option>
                }
                else
                {
                    <option value="@d.ToString().ToLower()">@d</option>
                }
            }
        </select>

        <a asp-action="Index" class="btn btn-outline-danger">
            <i class="bi bi-x-lg"></i>
        </a>

    </form>
    @if (!Model.Challenges.Any())
    {
        <div class="text-center py-5">

            <i class="bi bi-search display-5 text-muted"></i>

            <h5 class="mt-3 fw-semibold">No challenges found</h5>

            <p class="text-muted mb-3">
                Try adjusting your filters.
            </p>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Clear Filters
            </a>

        </div>
    }
    else
    {
        <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Difficulty</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var c in Model.Challenges)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @c.Title
                            </td>

                            <td>
                                <span class="badge
                                    @(c.Difficulty == "Easy" ? "bg-success" :
                                                                                                                  c.Difficulty == "Medium" ? "bg-warning text-dark" :
                                                                                                                  "bg-danger")">
                                    @c.Difficulty
                                </span>
                            </td>

                            <td>
                                <span class="badge @(c.IsDeleted ? "bg-danger" : "bg-success")">
                                    @(c.IsDeleted ? "Deleted" : "Active")
                                </span>
                            </td>

                            <td class="text-end">

                                <a asp-action="Edit"
                                       asp-route-id="@c.Id"
                                       class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil-square"></i>
                                    <span class="d-none d-md-inline ms-md-1">Edit</span>
                                </a>

                                @if (!c.IsDeleted)
                                {
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal-@c.Id">
                                        <i class="bi bi-trash"></i>
                                        <span class="d-none d-md-inline ms-md-1">Delete</span>
                                    </button>
                                }
                                else
                                {
                                    <form asp-action="Restore"
                                          asp-route-id="@c.Id"
                                          method="post"
                                          class="d-inline">

                                        <button type="submit"
                                                class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>
                                            Restore
                                        </button>

                                    </form>
                                }

                            </td>
                        </tr>

                        @if (!c.IsDeleted)
                        {
                            <partial name="_ConfirmDeletePartial" model="c" />
                        }
                    }
                </tbody>

            </table>

        </div>
     </div>   
    }
</div>
@if (Model.Challenges.Any())
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center admin-pagination">

            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                asp-route-search="@(Model.Search)" asp-route-state="@(Model.State)">
                    &laquo; Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                      asp-route-search="@(Model.Search?.ToLower())" asp-route-state="@(Model.State?.ToString().ToLower())">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-search="@(Model.Search?.ToLower())" asp-route-state="@(Model.State?.ToString().ToLower())">
                    Next &raquo;
                </a>
            </li>

        </ul>
    </nav>
}
