@model SubmissionsIndexViewModel

@{
    ViewData["Title"] = "Pending Submissions";
}

<div class="container mt-4 admin-submissions-page">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-hourglass-split me-2"></i>
            Pending Submissions
        </h2>
    </div>

    @if (!Model.Submissions.Any())
    {
        <div class="card admin-empty-card text-center p-4">
            <i class="bi bi-check-circle display-6 text-success mb-2"></i>
            <h5 class="mb-1">All caught up</h5>
            <p class="text-muted mb-0">No pending submissions at the moment.</p>
        </div>
    }
    else
    {
        <div class="card admin-table-card shadow-sm">
            <div class="table-responsive">

                <table class="table admin-table align-middle mb-0">

                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Challenge</th>
                            <th>Language</th>
                            <th>Submitted</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var s in Model.Submissions)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @s.UserDisplayName
                                </td>

                                <td>
                                    @s.ChallengeTitle
                                </td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @s.Language
                                    </span>
                                </td>

                                <td class="text-muted">
                                    @s.SubmittedAt.ToString(ApplicationConstants.DefaultDateFormat, CultureInfo.InvariantCulture)
                                </td>

                                <td class="text-end">
                                    <a asp-action="Review"
                                           asp-route-id="@s.SubmissionId"
                                           class="btn btn-success btn-sm">
                                        <i class="bi bi-eye me-1"></i>
                                        Review
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    }

</div>

@if (Model.Submissions.Any())
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center admin-pagination">

            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)">
                    Previous &laquo;
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)">
                    Next &raquo;
                </a>
            </li>

        </ul>
    </nav>
}
