@model SubmissionsIndexViewModel

@{
    ViewData["Title"] = "Pending Submissions";
}

<div class="container mt-4">

    <h2 class="mb-4">Pending Submissions</h2>

    @if (!Model.Submissions.Any())
    {
        <div class="alert alert-info">
            No pending submissions at the moment.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>User</th>
                    <th>Challenge</th>
                    <th>Language</th>
                    <th>Submitted</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var s in Model.Submissions)
                {
                    <tr>
                        <td>@s.UserDisplayName</td>
                        <td>@s.ChallengeTitle</td>
                        <td>
                            <span class="badge bg-secondary">
                                @s.Language
                            </span>
                        </td>
                        <td>@s.SubmittedAt.ToString(ApplicationConstants.DefaultDateFormat, CultureInfo.InvariantCulture)</td>

                        <td class="text-end">
                            <a asp-area="Admin"
                               asp-controller="Submissions"
                               asp-action="Details"
                               asp-route-id="@s.SubmissionId"
                               class="btn btn-primary btn-sm">
                                Review
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>
