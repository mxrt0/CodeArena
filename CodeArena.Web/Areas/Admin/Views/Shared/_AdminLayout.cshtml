<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - CodeArena Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="~/img/admin_logo.png" type="image/png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.css" />
    @RenderSection("Styles", required: false)
</head>
<body class="admin-body" id="appBody">

    <div class="container-fluid h-100">
        <div class="row h-100">
            <nav class="col-md-2 d-md-block sidebar collapse show" id="sidebarMenu">
                <div class="d-flex flex-column h-100 sidebar-inner">

                    <div class="sidebar-header text-center py-4">
                        <h4 class="fw-bold mb-1">
                            <i class="bi bi-shield-lock me-1"></i>
                            CodeArena
                        </h4>
                        <small class="text-muted">Admin Panel</small>
                        <hr class="mt-3" />
                    </div>

                    <div class="px-3 flex-grow-1">

                        <p class="sidebar-section">Navigation</p>
                        <ul class="nav flex-column mb-4">

                            <li class="nav-item">
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                                       asp-area="Admin" asp-controller="Dashboard">
                                    <i class="bi bi-speedometer2 me-2"></i>
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Challenges" ? "active" : "")"
                                       asp-area="Admin" asp-controller="Challenges">
                                    <i class="bi bi-trophy me-2"></i>
                                    Challenges
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Submissions" ? "active" : "")"
                                       asp-area="Admin" asp-controller="Submissions">
                                    <i class="bi bi-journal-code me-2"></i>
                                    Submissions
                                </a>
                            </li>

                        </ul>

                        <p class="sidebar-section">Actions</p>

                        <a class="btn btn-success w-100 mb-3"
                               asp-area="Admin"
                               asp-controller="Challenges"
                               asp-action="Create">
                            <i class="bi bi-plus-circle me-1"></i>
                            Create Challenge
                        </a>

                    </div>

                    <div class="p-3 border-top d-flex flex-column gap-2">

                        <button id="themeToggle" class="btn btn-outline-secondary w-25">
                            <i class="bi bi-moon"></i>
                        </button>

                        <form method="post"
                              asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">

                            <button type="submit" class="btn btn-outline-danger w-50">
                                <i class="bi bi-box-arrow-right me-1"></i>
                                Logout
                            </button>
                        </form>

                    </div>

                </div>
            </nav>

            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 py-4 main-content">

                <div class="toast-container position-fixed bottom-0 end-0 p-3">
                    <div id="adminToast" class="toast" role="alert">
                        <div class="toast-body" id="adminToastBody"></div>
                        <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
                    </div>
                </div>

                @await RenderSectionAsync("Back", false)
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js" integrity="sha512-lbwH47l/tPXJYG9AcFNoJaTMhGvYWhVM9YI43CT+uteTRRaiLCui8snIgyAN8XWgNjNhCqlAUdzZptso6OCoFQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <partial name="~/Views/Shared/_NotificationPartial.cshtml" />
    @RenderSection("Scripts", required: false)
</body>
</html>